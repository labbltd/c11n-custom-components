{
  "name": "LabbLtd_Extensions_BarclaysPayment",
  "label": "Barclays payment flow",
  "description": "Barclays payment flow",
  "organization": "LabbLtd",
  "version": "1.0.0",
  "library": "Extensions",
  "allowedApplications": [],
  "componentKey": "LabbLtd_Extensions_BarclaysPayment",
  "type": "Field",
  "subtype": "Text",
  "icon": "images/pz-text-input-active.svg",
  "properties": [
